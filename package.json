{
  "name": "scriptling",
  "displayName": "Scriptling Language Support",
  "description": "IntelliSense and language support for Scriptling extension libraries (ai, mcp, fuzzy, agent)",
  "version": "0.3.1",
  "publisher": "paularlott",
  "license": "MIT",
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/sponsors/paularlott"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paularlott/scriptling-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "scriptling",
    "python",
    "ai",
    "mcp",
    "llm"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "python",
        "extensions": [
          ".py",
          ".scriptling"
        ],
        "aliases": [
          "Python",
          "Scriptling"
        ]
      }
    ],
    "configuration": {
      "title": "Scriptling",
      "properties": {
        "scriptling.stubPath": {
          "type": "string",
          "default": "",
          "description": "Path to custom Scriptling type stubs directory (optional, bundled stubs are used by default)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "galleryBanner": {
    "color": "#1e3a5f",
    "theme": "dark"
  },
  "icon": "images/icon.png"
}
